# grok2api 环境变量示例
# 用法：复制为 .env 后按需修改；常规运行时配置优先改 ${DATA_DIR}/config.toml

# ==================== Docker Compose / 镜像 ====================
COMPOSE_PROJECT_NAME=grok2api
IMAGE_REPO=ghcr.io/aurora-develop/grok2api
IMAGE_TAG=latest
IMAGE_PULL_POLICY=always

# ==================== 基础运行 ====================
TZ=Asia/Shanghai
LOG_LEVEL=INFO
# 写入本地文件日志
LOG_FILE_ENABLED=true
# 账号目录增量同步间隔（秒）
ACCOUNT_SYNC_INTERVAL=30

# ==================== Web 服务 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Docker Compose 宿主机映射端口
HOST_PORT=8000

# ==================== 代理 ====================
# HTTP/HTTPS/SOCKS5 代理（覆盖 config.toml 中的 proxy.egress.proxy_url）
# 示例: http://127.0.0.1:7890  socks5://127.0.0.1:1080
PROXY_HTTP=

# ==================== 账号存储（启动期） ====================
# 可选：local | redis | mysql | postgresql（当前 Go 版仅实现 local）
ACCOUNT_STORAGE=local
ACCOUNT_LOCAL_PATH=./data/accounts.jsonl

# ==================== 本地数据 / 日志目录 ====================
DATA_DIR=./data
LOG_DIR=./logs
